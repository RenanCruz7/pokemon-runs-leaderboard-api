# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://your-db-host:5432/leaderboard_db
SPRING_DATASOURCE_USERNAME=your-db-username
SPRING_DATASOURCE_PASSWORD=your-db-password

# Optional local Docker PostgreSQL settings
POSTGRES_DB=leaderboard_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Optional local Docker MySQL settings
MYSQL_DATABASE=leaderboard_db
MYSQL_USER=leaderboard
MYSQL_PASSWORD=leaderboard
MYSQL_ROOT_PASSWORD=root

# JPA/Hibernate Configuration
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_FORMAT_SQL=false

# Cache / Redis Configuration
SPRING_CACHE_TYPE=redis
SPRING_CACHE_REDIS_TTL=10m
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# JWT Secret (use a long random value in production)
API_SECURITY_TOKEN_SECRET=replace-with-a-long-random-secret

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.example.com

# Server port
PORT=8080
